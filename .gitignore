# === Assistente Virtual Local — .gitignore ===

# Variáveis de ambiente (NUNCA commitar)
.env

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
dist/
build/
*.egg
.venv/
venv/
env/
.conda_env/

# Cache de áudio gerado pelo TTS
/backend/audio_cache/*.mp3
/backend/audio_cache/*.wav

# Dados de memória (ChromaDB e SQLite)
/backend/memory/*.db
/backend/memory/*.db-*
/backend/memory/chroma/
/backend/memory/chroma_data/

# IDE
.vscode/
.idea/
*.swp
*.swo
.windsurf/

# OS
.DS_Store
Thumbs.db

# Logs
*.log
logs/*.log
logs/*.zip

# Frontend / Tauri
frontend/node_modules/
frontend/src-tauri/target/
frontend/src-tauri/gen/
