# === Assistente Virtual Local — Variáveis de Ambiente ===

# --- IA / LLM Provider ---
# Escolha qual provider usar: claude, gemini, openai, deepseek, ollama
LLM_PROVIDER=claude

# Claude (Anthropic)
ANTHROPIC_API_KEY=

# Gemini (Google)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash-exp

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# DeepSeek
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# Ollama (Local)
OLLAMA_MODEL=gemma3:4b-it-qat
OLLAMA_BASE_URL=http://localhost:11434

# --- Google Calendar ---
GOOGLE_CALENDAR_CREDENTIALS_PATH=

# --- Spotify ---
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# --- Telegram ---
TELEGRAM_BOT_TOKEN=

# --- Wake Word (Porcupine) ---
PORCUPINE_ACCESS_KEY=

# --- Ambiente ---
ENV=development
